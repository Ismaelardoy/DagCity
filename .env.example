# --- DagCity Configuration Example ---
# NOTE: This file is OPTIONAL.
# If you don't create a .env file, DagCity will still work!
# You will just need to Drag & Drop your manifest.json manually.
# Create this .env ONLY if you want automatic "One-Click Live Sync".

# Rename this file to .env and set your paths

# Path on your HOST machine to the dbt project folder.
# You can use ABSOLUTE paths (e.g., "C:/Users/name/dbt project") 
# or RELATIVE paths (e.g., "../my-dbt-project").
# IMPORTANT: If your path has SPACES, wrap it in double quotes!
HOST_PROJECT_PATH="./dbt_project"

# Path RELATIVE to the project root to the manifest.json
# (Standard dbt: target/manifest.json)
# OPTIONAL: DagCity will try to find it automatically if you leave it blank.
MANIFEST_SUBPATH=target/manifest.json

# Visualizer Server Port
PORT=8080
