# --- DagCity Configuration ---
# Use this file to define where your dbt data is located.

# Path on your HOST machine to the dbt project folder
# This can be absolute (e.g. C:\Users\...) or relative to dagcity/
HOST_PROJECT_PATH=../jaffle_shop_duckdb

# Path RELATIVE to the project root to the manifest.json
# Default dbt projects have it at: target/manifest.json
MANIFEST_SUBPATH=target/manifest.json

# Visualizer Server Port
PORT=8080
